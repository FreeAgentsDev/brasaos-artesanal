---
import BrandLogo from './BrandLogo.astro';

interface Post {
  shortcode: string;
  url: string;
  caption: string;
  likes: number;
  image_urls: string[];
  timestamp: string;
}

interface Props {
  posts: Post[];
  instagramUrl: string;
}

const { posts, instagramUrl } = Astro.props;

function preview(caption: string, max = 120): string {
  const t = caption.replace(/\s+/g, ' ').trim();
  return t.length > max ? t.slice(0, max) + '…' : t;
}
---

<section class="border-t border-white/5 bg-coal-900/30 py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="flex flex-col justify-between gap-6 md:flex-row md:items-end">
      <div class="flex flex-col gap-5 sm:flex-row sm:items-start sm:gap-6">
        <BrandLogo imgClass="h-12 w-auto shrink-0 sm:h-14" />
        <div>
        <h2 class="font-display text-3xl font-semibold text-white">Del horno a tu feed</h2>
        <p class="mt-2 max-w-xl text-stone-400">
          Últimas publicaciones del perfil analizado. Las imágenes se descargaron localmente para esta demo.
        </p>
        </div>
      </div>
      <a
        href={instagramUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex w-fit items-center gap-2 rounded-full border border-white/15 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-white/5"
      >
        Seguir en Instagram
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        posts.slice(0, 6).map((post) => {
          const img = post.image_urls[0];
          return (
            <a
              href={post.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group overflow-hidden rounded-2xl border border-white/5 bg-coal-900/50 transition hover:border-ember-500/30"
            >
              {img ? (
                <div class="aspect-[4/3] overflow-hidden">
                  <img
                    src={img}
                    alt=""
                    class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                    loading="lazy"
                    width={800}
                    height={600}
                  />
                </div>
              ) : (
                <div class="aspect-[4/3] bg-coal-800" />
              )}
              <div class="p-4">
                <p class="line-clamp-3 text-sm text-stone-400">{preview(post.caption)}</p>
                <p class="mt-3 text-xs text-stone-600">
                  {post.likes.toLocaleString('es-CO')} me gusta ·{' '}
                  {post.timestamp.slice(0, 10)}
                </p>
              </div>
            </a>
          );
        })
      }
    </div>
  </div>
</section>
