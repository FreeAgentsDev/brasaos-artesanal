---
import { SITE } from '../config/site';

const { googleReviews } = SITE;
---

<section
  id="visitanos"
  class="scroll-mt-24 border-t border-white/5 bg-coal-900/40 py-16 sm:py-20 lg:py-24"
  aria-labelledby="visitanos-heading"
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-500/90">Ubicación</p>
      <h2 id="visitanos-heading" class="font-display mt-2 text-3xl font-semibold text-white sm:text-4xl">
        Visítanos en La Estrella
      </h2>
      <p class="mt-3 text-stone-400">
        Pizzería en Manizales. Datos de contacto y reseñas basados en la ficha pública de{' '}
        <a
          href={SITE.googleMapsPlaceUrl}
          class="text-amber-400 underline-offset-2 hover:underline"
          target="_blank"
          rel="noopener noreferrer"
        >
          Google Maps
        </a>
        .
      </p>
    </div>

    <div class="mt-12 grid gap-10 lg:grid-cols-2 lg:items-start lg:gap-12">
      <div class="min-w-0">
        <div class="overflow-hidden rounded-2xl border border-white/10 bg-coal-950 shadow-xl ring-1 ring-white/5">
          <iframe
            src={SITE.googleMapsEmbedSrc}
            title="Ubicación de Brasaos Artesana en Google Maps"
            width="600"
            height="450"
            class="h-[min(52vh,420px)] w-full sm:h-[450px]"
            style="border:0"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
        <a
          href={SITE.googleMapsPlaceUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-flex w-full touch-manipulation items-center justify-center rounded-2xl border border-white/15 bg-white/5 px-4 py-3 text-sm font-semibold text-white transition hover:bg-white/10 sm:w-auto"
        >
          Abrir en Google Maps
        </a>
      </div>

      <div class="flex flex-col gap-8">
        <div class="rounded-2xl border border-white/10 bg-coal-950/60 p-6 sm:p-8">
          <h3 class="text-sm font-semibold uppercase tracking-wider text-stone-500">Contacto</h3>
          <address class="mt-4 not-italic text-stone-300">
            <p class="leading-relaxed">{SITE.addressLine}</p>
            <p class="mt-3">
              <a href={`tel:${SITE.phoneTel}`} class="text-lg font-semibold text-amber-300 hover:underline">
                {SITE.phoneDisplay}
              </a>
            </p>
          </address>
          <p class="mt-4 text-xs text-stone-600">{SITE.googleReviews.priceNote}</p>
        </div>

        <div class="rounded-2xl border border-amber-500/20 bg-gradient-to-b from-amber-950/30 to-coal-950/80 p-6 sm:p-8">
          <div class="flex flex-wrap items-end gap-3">
            <p class="font-display text-4xl font-bold tabular-nums text-white">{googleReviews.rating}</p>
            <div class="flex flex-col">
              <div class="flex gap-0.5 text-amber-400" aria-hidden="true">
                {Array.from({ length: 5 }).map((_, i) => (
                  <span class={i < Math.floor(googleReviews.rating) ? '' : 'opacity-40'}>★</span>
                ))}
              </div>
              <p class="text-sm text-stone-400">
                {googleReviews.reviewCount} opiniones en Google · Pizzería
              </p>
            </div>
          </div>
          <p class="mt-4 text-xs text-stone-500">
            Lo que más destacan quienes opinan (según resumen de Google):{' '}
            {googleReviews.highlights.join(' · ')}.
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            {googleReviews.highlights.map((tag) => (
              <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-medium text-stone-300">
                {tag}
              </span>
            ))}
          </div>
        </div>

        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider text-stone-500">Opiniones recientes</h3>
          <ul class="mt-4 space-y-4">
            {googleReviews.testimonials.map((t) => (
              <li>
                <blockquote class="rounded-2xl border border-white/10 bg-coal-950/50 p-5 text-stone-300">
                  <p class="text-sm leading-relaxed text-stone-200">“{t.text}”</p>
                  <footer class="mt-4 flex flex-wrap items-center justify-between gap-2 border-t border-white/5 pt-3 text-xs text-stone-500">
                    <cite class="font-semibold not-italic text-stone-400">{t.author}</cite>
                    <span class="text-amber-500/90" aria-label={`${t.stars} de 5 estrellas`}>
                      {Array.from({ length: t.stars })
                        .map(() => '★')
                        .join('')}
                      {Array.from({ length: 5 - t.stars })
                        .map(() => '☆')
                        .join('')}
                    </span>
                  </footer>
                </blockquote>
              </li>
            ))}
          </ul>
          <a
            href={SITE.googleMapsPlaceUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 inline-flex text-sm font-medium text-amber-400 hover:underline"
          >
            Leer más opiniones en Google →
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
