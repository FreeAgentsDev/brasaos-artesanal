---
import BrandLogo from './BrandLogo.astro';
import { SITE } from '../config/site';
---

<footer class="border-t border-white/5 bg-coal-950 py-14">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mb-12 flex flex-col items-center border-b border-white/5 pb-12 sm:items-start">
      <BrandLogo imgClass="h-16 w-auto sm:h-[4.5rem]" />
      <p class="mt-4 text-center text-sm text-stone-500 sm:text-left">{SITE.tagline}</p>
    </div>
    <div class="grid gap-10 md:grid-cols-3">
      <div>
        <p class="text-sm font-medium text-stone-300">Horario</p>
        <ul class="mt-3 space-y-2 text-sm text-stone-500">
          {SITE.hours.map((h) => (
            <li>
              <span class="text-stone-400">{h.days}:</span> {h.time}
            </li>
          ))}
        </ul>
      </div>
      <div>
        <p class="text-sm font-medium text-stone-300">Ubicación</p>
        <p class="mt-3 text-sm leading-relaxed text-stone-500">{SITE.addressLine}</p>
        <p class="mt-2">
          <a href={`tel:${SITE.phoneTel}`} class="text-sm font-medium text-amber-400 hover:underline">
            {SITE.phoneDisplay}
          </a>
        </p>
        <p class="mt-2">
          <a
            href={SITE.googleMapsPlaceUrl}
            class="text-sm text-stone-500 hover:text-amber-400 hover:underline"
            target="_blank"
            rel="noopener noreferrer"
          >
            Ver en Google Maps
          </a>
        </p>
      </div>
      <div>
        <p class="text-sm font-medium text-stone-300">Enlaces</p>
        <ul class="mt-3 space-y-2 text-sm">
          <li>
            <a href={SITE.instagramUrl} class="text-ember-400 hover:underline" target="_blank" rel="noopener">
              Instagram
            </a>
          </li>
          <li>
            <a href="#pedido" class="text-ember-400 hover:underline">Pedido con carrito (WhatsApp)</a>
          </li>
          <li>
            <a
              href={SITE.whatsappReservationUrl}
              class="text-[#25D366] hover:underline"
              target="_blank"
              rel="noopener noreferrer"
            >
              Reservar mesa (WhatsApp)
            </a>
          </li>
        </ul>
      </div>
    </div>
    <p class="mt-12 text-center text-xs text-stone-600">
      Sitio de demostración · Menú basado en export Foodbooking · No afiliado oficialmente salvo que el local lo publique.
    </p>
  </div>
</footer>
