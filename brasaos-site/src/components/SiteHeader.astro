---
import { SITE } from '../config/site';
import BrandLogo from './BrandLogo.astro';
---

<header
  class="fixed inset-x-0 top-0 z-40 border-b border-white/5 bg-coal-950/90 backdrop-blur-md supports-[backdrop-filter]:bg-coal-950/80"
>
  <div class="mx-auto flex h-14 max-w-6xl items-center justify-between gap-3 px-3 sm:h-16 sm:px-6">
    <a href="/" class="flex min-w-0 items-center gap-2 outline-offset-4 focus-visible:rounded-md">
      <BrandLogo imgClass="h-8 w-auto sm:h-10" />
    </a>
    <nav class="flex shrink-0 items-center gap-1 text-sm sm:gap-3">
      <a
        href="#menu"
        class="rounded-full px-2.5 py-2 text-stone-300 transition hover:bg-white/5 hover:text-white sm:px-3"
        >Menú</a
      >
      <a
        href="#visitanos"
        class="hidden rounded-full px-2.5 py-2 text-stone-300 transition hover:bg-white/5 hover:text-white sm:inline-block sm:px-3"
        >Local</a
      >
      <button
        type="button"
        id="header-cart-open"
        class="relative flex items-center gap-1.5 rounded-full border border-white/10 bg-white/5 px-2.5 py-2 text-stone-200 transition hover:bg-white/10 sm:gap-2 sm:px-3"
        aria-label="Abrir carrito"
        aria-haspopup="dialog"
        aria-controls="cart-dialog"
      >
        <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15a3 3 0 0 0-3-3m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
        </svg>
        <span class="hidden sm:inline">Pedido</span>
        <span
          id="header-cart-badge"
          class="absolute -right-0.5 -top-0.5 flex h-5 min-w-[1.25rem] items-center justify-center rounded-full bg-ember-500 px-1 text-[10px] font-bold text-white opacity-0 transition-opacity"
          aria-hidden="true"
          >0</span
        >
      </button>
      <a
        href={SITE.instagramUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden rounded-full border border-ember-500/40 bg-ember-600/20 px-3 py-2 font-medium text-ember-200 transition hover:bg-ember-600/30 md:inline-flex"
        >IG</a
      >
    </nav>
  </div>
</header>
