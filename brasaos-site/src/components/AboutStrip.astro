---
import BrandLogo from './BrandLogo.astro';

interface Props {
  biography: string;
  externalUrl: string;
}

const { biography, externalUrl } = Astro.props;
const lines = biography.split('\n').filter(Boolean);
---

<section class="py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
      <div>
        <h2 class="font-display text-3xl font-semibold text-white sm:text-4xl">Sabor de verdad</h2>
        <div class="mt-6 space-y-4 text-lg text-stone-400">
          {lines.map((line) => (
            <p>{line}</p>
          ))}
        </div>
        <a
          href={externalUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-8 inline-flex rounded-full border border-ember-500/30 bg-ember-600/10 px-6 py-3 text-sm font-semibold text-ember-100 transition hover:bg-ember-600/20"
        >
          Ver enlaces y pedidos
        </a>
      </div>
      <div class="relative">
        <div class="absolute -inset-4 rounded-3xl bg-gradient-to-br from-ember-500/20 to-transparent blur-2xl"></div>
        <div class="relative rounded-3xl border border-white/10 bg-coal-900/80 p-8 backdrop-blur">
          <div class="mb-6 flex justify-center sm:justify-start">
            <BrandLogo imgClass="h-16 w-auto sm:h-[4.5rem]" />
          </div>
          <p class="font-display text-xl text-white">Pizza Máster Manizales</p>
          <p class="mt-3 text-stone-400">
            Tricampeones 2023–2025 según la biografía del perfil analizado: una referencia clara para quienes
            buscan pizzas de autor en la ciudad.
          </p>
          <ul class="mt-6 space-y-3 text-sm text-stone-500">
            <li class="flex gap-2">
              <span class="text-ember-400">✓</span> Masa madurada (biga) y ingredientes cuidados en recetas propias.
            </li>
            <li class="flex gap-2">
              <span class="text-ember-400">✓</span> Cocina tipo italiana con toque local (uchuvas, miel roja, etc.).
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
