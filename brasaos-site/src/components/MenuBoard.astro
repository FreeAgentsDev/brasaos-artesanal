---
import BrandLogo from './BrandLogo.astro';
import type { MenuCategory } from '../scripts/cart';
import { formatCOP } from '../scripts/cart';

interface Props {
  menu: MenuCategory[];
}

const { menu } = Astro.props;

function slug(s: string): string {
  return s
    .toLowerCase()
    .normalize('NFD')
    .replace(/\p{M}/gu, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/(^-|-$)/g, '');
}
---

<section id="menu" class="scroll-mt-24 rounded-t-[2rem] bg-white pb-28 text-stone-900 sm:pb-16">
  <div class="mx-auto max-w-6xl px-3 py-12 sm:px-6 sm:py-16 lg:py-20">
    <div class="flex max-w-3xl flex-col gap-6 sm:flex-row sm:items-start sm:gap-8">
      <BrandLogo variant="onLight" imgClass="h-11 w-auto sm:h-12" />
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-stone-500">Carta</p>
        <h2 class="font-display mt-2 text-3xl font-semibold text-stone-950 sm:text-4xl">Nuestro menú</h2>
        <p class="mt-3 text-stone-600">
          Fotos y precios alineados con el catálogo en{' '}
          <a
            href="https://www.foodbooking.com/ordering/restaurant/menu?restaurant_uid=7220a987-ec7d-4b49-abc4-aa5c676e502d&dine_in=true"
            class="font-medium text-amber-700 underline-offset-2 hover:underline"
            target="_blank"
            rel="noopener noreferrer"
          >
            Foodbooking
          </a>
          . Usa la búsqueda y el carrito rápido en cada plato.
        </p>
      </div>
    </div>

    <!-- Barra fija: búsqueda + categorías -->
    <div
      id="menu-toolbar"
      class="sticky top-14 z-30 -mx-4 mb-8 border-b border-stone-100 bg-white/95 px-3 py-3 backdrop-blur-md transition-shadow duration-300 sm:top-16 sm:-mx-6 sm:mb-10 sm:px-6 sm:py-4"
    >
      <label for="menu-search" class="sr-only">Buscar en el menú</label>
      <div class="relative">
        <svg
          class="pointer-events-none absolute left-3.5 top-1/2 h-5 w-5 -translate-y-1/2 text-stone-400"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"
          ></path>
        </svg>
        <input
          id="menu-search"
          type="search"
          name="menu-search"
          enterkeyhint="search"
          autocomplete="off"
          placeholder="Buscar plato, ingrediente…"
          class="w-full rounded-2xl border border-stone-200 bg-stone-50 py-3.5 pl-12 pr-12 text-base text-stone-900 shadow-sm placeholder:text-stone-400 focus:border-amber-400 focus:bg-white focus:outline-none focus:ring-4 focus:ring-amber-400/20"
        />
        <button
          type="button"
          id="menu-search-clear"
          class="absolute right-2 top-1/2 hidden h-10 w-10 -translate-y-1/2 rounded-xl text-xl text-stone-500 transition hover:bg-stone-200/80 hover:text-stone-800"
          aria-label="Limpiar búsqueda"
        >
          ×
        </button>
      </div>
      <p id="menu-search-count" class="mt-2 hidden text-center text-sm font-medium text-amber-800" aria-live="polite"
      ></p>
      <div class="mt-5">
        <p class="mb-2 flex items-center gap-2 text-xs font-medium uppercase tracking-wide text-stone-500">
          <span
            class="inline-flex shrink-0 items-center gap-0.5 text-amber-600"
            aria-hidden="true"
          >
            <svg class="menu-pill-hint h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
            </svg>
            <svg class="menu-pill-hint-alt h-4 w-4 opacity-70" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
            </svg>
          </span>
          <span>Desliza horizontalmente para elegir categoría</span>
        </p>
        <div class="relative -mx-1 min-h-[3.25rem]">
          <div
            class="pointer-events-none absolute inset-y-0 left-0 z-10 w-10 bg-gradient-to-r from-white from-40% to-transparent sm:w-12"
            aria-hidden="true"
          >
          </div>
          <div
            class="pointer-events-none absolute inset-y-0 right-0 z-10 w-10 bg-gradient-to-l from-white from-40% to-transparent sm:w-12"
            aria-hidden="true"
          >
          </div>
          <div
            id="menu-cat-pills-track"
            class="no-scrollbar flex snap-x snap-mandatory gap-2 overflow-x-auto overflow-y-hidden scroll-smooth px-1 pb-2 pt-0.5"
            role="tablist"
            aria-label="Ir a categoría"
          >
            {
              menu.map((cat) => (
                <a
                  href={`#cat-${slug(cat.category)}`}
                  data-slug={slug(cat.category)}
                  class="menu-cat-pill snap-start shrink-0 rounded-full border border-stone-200 bg-stone-50 px-4 py-2.5 text-sm font-medium text-stone-700 shadow-sm ring-1 ring-stone-200/60 transition hover:border-amber-300 hover:bg-amber-50 hover:text-stone-900 hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-amber-500"
                >
                  {cat.category}
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <div
      id="menu-no-results"
      class="hidden rounded-2xl border border-dashed border-stone-200 bg-stone-50 px-6 py-14 text-center"
      role="status"
    >
      <p class="text-lg font-medium text-stone-700">No encontramos platos con ese criterio</p>
      <p class="mt-2 text-sm text-stone-500">Prueba otra palabra o limpia la búsqueda.</p>
    </div>

    <div id="menu-categories-root" class="space-y-4 sm:space-y-5">
      {
        menu.map((cat) => (
          <details
            id={`cat-${slug(cat.category)}`}
            data-menu-category={slug(cat.category)}
            class="menu-category-details group scroll-mt-48 overflow-hidden rounded-2xl border border-stone-200 bg-stone-50/40 open:bg-white open:shadow-md lg:scroll-mt-52 [&_summary::-webkit-details-marker]:hidden"
            open
          >
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-4 py-4 transition hover:bg-stone-100/80 sm:px-5 sm:py-5">
              <span class="flex min-w-0 flex-1 flex-col gap-1 sm:flex-row sm:items-baseline sm:gap-3">
                <span class="font-display text-lg font-semibold uppercase tracking-wide text-stone-950 sm:text-xl">
                  {cat.category}
                </span>
                <span class="shrink-0 text-sm text-stone-500">
                  {cat.items.length} {cat.items.length === 1 ? 'plato' : 'platos'}
                </span>
              </span>
              <span
                class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-stone-200 bg-white text-stone-500 transition group-open:rotate-180"
                aria-hidden="true"
              >
                <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                </svg>
              </span>
            </summary>

            <div class="border-t border-stone-200 px-3 pb-5 pt-4 sm:px-5 sm:pb-6">
              {cat.categoryDescription ? (
                <p class="mb-4 max-w-3xl whitespace-pre-line text-sm leading-relaxed text-stone-600 sm:text-base">
                  {cat.categoryDescription}
                </p>
              ) : null}

              {cat.categoryImage ? (
                <div class="mb-6 overflow-hidden rounded-2xl border border-stone-100">
                  <img
                    src={cat.categoryImage}
                    alt=""
                    class="max-h-48 w-full object-cover sm:max-h-56"
                    loading="lazy"
                    decoding="async"
                    width={800}
                    height={400}
                  />
                </div>
              ) : null}

              <ul class="divide-y divide-stone-200 border-t border-stone-200">
                {cat.items.map((item) => (
                  <li
                    class="menu-item-row rounded-xl px-0.5 py-1 transition hover:bg-stone-50/90 sm:px-1"
                    data-item-id={item.id}
                    data-search={`${item.name} ${item.description ?? ''}`}
                    data-category-name={cat.category}
                  >
                    <div class="flex gap-4 py-4 first:pt-4">
                      <button
                        type="button"
                        class="menu-card-media group/img relative h-20 w-20 shrink-0 overflow-hidden rounded-xl bg-stone-100 ring-1 ring-stone-200/80 sm:h-24 sm:w-24"
                        data-menu-open={item.id}
                        aria-label={`Ver detalle de ${item.name}`}
                      >
                        {item.image ? (
                          <img
                            src={item.image}
                            alt=""
                            class="h-full w-full object-cover transition duration-300 group-hover/img:scale-105"
                            loading="lazy"
                            decoding="async"
                            width={192}
                            height={192}
                          />
                        ) : (
                          <div class="h-full w-full bg-gradient-to-br from-stone-100 to-stone-200" aria-hidden="true" />
                        )}
                        <span class="absolute bottom-1 right-1 rounded bg-white/95 px-1.5 py-0.5 text-[10px] font-bold uppercase tracking-wide text-amber-800 shadow-sm">
                          Info
                        </span>
                      </button>

                      <div class="min-w-0 flex-1">
                        <div class="flex flex-wrap items-baseline justify-between gap-2">
                          <h4 class="text-base font-semibold leading-snug text-stone-950 sm:text-lg">{item.name}</h4>
                          <span class="font-display shrink-0 tabular-nums text-base font-semibold text-stone-900 sm:text-lg">
                            {formatCOP(item.price)}
                          </span>
                        </div>
                        {item.description ? (
                          <p class="mt-1 text-sm leading-relaxed text-stone-600 line-clamp-3 sm:line-clamp-none">
                            {item.description}
                          </p>
                        ) : null}

                        <div class="mt-3 flex flex-wrap items-center gap-2 sm:mt-4">
                          <button
                            type="button"
                            data-menu-open={item.id}
                            class="text-xs font-semibold text-amber-700 underline-offset-2 hover:underline sm:text-sm"
                          >
                            Ver más detalle
                          </button>
                          <div
                            data-menu-stepper
                            class="hidden items-center gap-0.5 rounded-full border border-amber-400/60 bg-amber-50 p-1 shadow-sm"
                          >
                            <button
                              type="button"
                              class="menu-qty-dec flex h-11 min-w-[2.75rem] touch-manipulation items-center justify-center rounded-full text-xl font-medium text-stone-700 transition hover:bg-amber-100 active:scale-95"
                              data-id={item.id}
                              aria-label={`Quitar ${item.name}`}
                            >
                              −
                            </button>
                            <span
                              data-menu-qty
                              class="min-w-[1.75rem] text-center text-base font-bold tabular-nums text-stone-900"
                            >
                              0
                            </span>
                            <button
                              type="button"
                              class="menu-qty-inc flex h-11 min-w-[2.75rem] touch-manipulation items-center justify-center rounded-full text-xl font-medium text-stone-700 transition hover:bg-amber-100 active:scale-95"
                              data-id={item.id}
                              aria-label={`Añadir ${item.name}`}
                            >
                              +
                            </button>
                          </div>
                          <button
                            type="button"
                            data-menu-add
                            data-id={item.id}
                            data-name={item.name}
                            data-price={String(item.price)}
                            class="inline-flex min-h-[44px] touch-manipulation items-center justify-center rounded-full border border-amber-600 bg-amber-500 px-5 py-2.5 text-sm font-bold text-white shadow-sm transition hover:bg-amber-600 active:scale-[0.98]"
                          >
                            Añadir al pedido
                          </button>
                        </div>
                      </div>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          </details>
        ))
      }
    </div>

    <!-- Detalle de producto -->
    <dialog
      id="menu-item-dialog"
      class="menu-item-dialog z-[70] w-[calc(100vw-1.5rem)] max-w-lg overflow-hidden rounded-3xl border border-stone-200 bg-white p-0 text-stone-900 shadow-2xl backdrop:bg-stone-950/60 sm:w-full"
      aria-labelledby="menu-dialog-title"
    >
      <div class="flex max-h-[min(90vh,720px)] flex-col">
        <div class="relative shrink-0 border-b border-stone-100 bg-stone-50/80">
          <button
            type="button"
            id="menu-dialog-close"
            class="absolute right-2 top-2 z-10 flex h-11 w-11 items-center justify-center rounded-full bg-white/95 text-2xl leading-none text-stone-600 shadow-md backdrop-blur transition hover:bg-white hover:text-stone-900"
            aria-label="Cerrar"
          >
            ×
          </button>
          <div id="menu-dialog-image-wrap" class="aspect-[16/10] w-full overflow-hidden bg-stone-100"></div>
        </div>
        <div id="menu-dialog-body" class="min-h-0 flex-1 overflow-y-auto overscroll-contain px-5 pb-6 pt-4 sm:px-6">
          <p id="menu-dialog-category" class="text-xs font-semibold uppercase tracking-wider text-amber-700"></p>
          <h3 id="menu-dialog-title" class="font-display mt-1 text-2xl font-semibold text-stone-950"></h3>
          <p id="menu-dialog-price" class="mt-2 font-display text-xl tabular-nums text-stone-800"></p>
          <p id="menu-dialog-desc" class="mt-4 text-sm leading-relaxed text-stone-600 sm:text-base"></p>
          <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
            <button
              type="button"
              id="menu-dialog-add"
              class="inline-flex min-h-[48px] flex-1 items-center justify-center rounded-full border border-amber-600 bg-amber-500 px-6 py-3 text-sm font-bold text-white shadow-sm transition hover:bg-amber-600"
            >
              Añadir al pedido
            </button>
            <button
              type="button"
              id="menu-dialog-close-secondary"
              class="inline-flex min-h-[48px] items-center justify-center rounded-full border border-stone-200 bg-white px-6 py-3 text-sm font-semibold text-stone-700 transition hover:bg-stone-50"
            >
              Cerrar
            </button>
          </div>
        </div>
      </div>
    </dialog>
  </div>

  <!-- Confirmación rápida al añadir -->
  <div
    id="menu-toast"
    class="pointer-events-none fixed bottom-[5.5rem] left-1/2 z-40 w-[calc(100%-2rem)] max-w-md -translate-x-1/2 translate-y-4 opacity-0 transition duration-300 sm:bottom-28"
    role="status"
    aria-live="polite"
  >
    <div
      class="pointer-events-auto flex flex-wrap items-center justify-center gap-2 rounded-2xl border border-stone-200 bg-white px-4 py-3.5 text-sm text-stone-800 shadow-2xl sm:gap-3 sm:px-5"
    >
      <span class="text-lg text-emerald-600" aria-hidden="true">✓</span>
      <span class="font-medium">Añadido al pedido</span>
      <button
        type="button"
        id="cart-toast-open"
        class="font-bold text-amber-700 underline-offset-2 hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-amber-500 rounded"
      >
        Ver pedido
      </button>
    </div>
  </div>
</section>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .menu-item-dialog::backdrop {
    background: rgb(28 25 23 / 0.55);
  }
  @keyframes menu-pill-shimmer {
    0%,
    100% {
      transform: translateX(0);
      opacity: 0.85;
    }
    50% {
      transform: translateX(6px);
      opacity: 1;
    }
  }
  .menu-pill-hint {
    animation: menu-pill-shimmer 2.2s ease-in-out infinite;
  }
  .menu-pill-hint-alt {
    animation: menu-pill-shimmer 2.2s ease-in-out infinite;
    animation-delay: 0.35s;
  }
  @media (prefers-reduced-motion: reduce) {
    .menu-pill-hint,
    .menu-pill-hint-alt {
      animation: none;
    }
  }
</style>

<script>
  import '../scripts/menu-interactive';
</script>
